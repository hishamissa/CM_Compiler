/*
 * Test 1: Clean Program w/ No Errors
 * 
 * This program should compile without any syntax or semantic errors.
 * Tests:
 * - Global variable declarations
 * - Function declarations with parameters
 * - Local variable declarations
 * - Array declarations and usage
 * - Function calls with correct arguments
 * - Return statements with correct types
 * - Control flow statements (if/while)
 * - Arithmetic and boolean operations
 */

int x;
int arr[10];
bool flag;

int max(int a, int b) {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

void processArray(int data[], int size) {
    int i;
    i = 0;
    while (i < size) {
        data[i] = i * 2;
        i = i + 1;
    }
}

void main(void) {
    int result;
    int y;
    
    x = 10;
    y = 20;
    result = max(x, y);
    
    flag = result > 15;
    
    if (flag) {
        output(result);
    }
    
    processArray(arr, 10);
    output(arr[5]);
}