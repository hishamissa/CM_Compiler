int x;
bool flag;

int factorial(int n) {
    int result;
    result = 1;
    
    while (n > 1) {
        result = result * n;
        n = n - 1;
    }
    
    return result;
}

void main(void) {
    int num;
    int fact;
    
    num = input();
    
    if (num > 0) {
        fact = factorial(num);
        output(fact);
    } else {
        output(0);
    }
}