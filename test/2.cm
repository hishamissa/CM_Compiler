/* Test 2: Recursive function and boolean variable
   Input: a positive integer
   Expected: outputs factorial of input */
int factorial(int n) {
    if (n <= 1) {
        return 1;
    } else {
        return n * factorial(n - 1);
    }
}

void main(void) {
    int x;
    bool done;
    x = input();
    done = x > 0;
    if (done) {
        output(factorial(x));
    } else {
        output(0);
    }
}
