/*
 * Test 3: Type Checking Errors
 * 
 * This test has exactly 3 semantic errors related to type mismatches:
 * Error 1 (Line 15): Cannot add bool and int (type mismatch in arithmetic)
 * Error 2 (Line 16): Cannot assign bool to int variable
 * Error 3 (Line 17): Array index must be int, not bool
 */

void main(void) {
    int x;
    bool flag;
    int nums[5];
    
    x = flag + 10;
    x = flag;
    x = nums[flag];
    
    output(x);
}