/* Test 3: Global array, function with array parameter,
   nested while loops. Input: 5 integers.
   Expected: outputs them in reverse order */
int a[5];

void reverse(int arr[], int size) {
    int i;
    i = size - 1;
    while (i >= 0) {
        output(arr[i]);
        i = i - 1;
    }
}

void main(void) {
    int i;
    i = 0;
    while (i < 5) {
        a[i] = input();
        i = i + 1;
    }
    reverse(a, 5);
}
