/*
 * Test 4: Function Call and Return Errors
 * 
 * This test has exactly 3 semantic errors related to functions:
 * Error 1 (Line 17): Void function 'doNothing' cannot return a value
 * Error 2 (Line 24): Function 'add' expects 2 arguments but receives 1
 * Error 3 (Line 25): Argument type mismatch - passing bool to int parameter
 */

int add(int a, int b) {
    return a + b;
}

void doNothing(void) {
    int x;
    x = 5;
    return x;
}

void main(void) {
    int result;
    bool flag;
    
    result = add(10);
    result = add(flag, 20);
    output(result);
}